# Local timezone
TZ=Asia/Seoul
GENERIC_TIMEZONE=Asia/Seoul
N8N_HOST=localhost

# AI provider keys. Mock mode does not require these.
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# YouTube trend lookup and upload.
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public
TREND_REGION=US
TREND_VIDEO_CATEGORY_ID=0
TREND_MAX_RESULTS=5
CONFIRM_PUBLIC_UPLOAD=

# Optional future keys.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_SHEETS_ID=
